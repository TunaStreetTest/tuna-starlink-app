# Copy to backend/.env.local for local dev.

# Free testing — no xAI spend, placeholder cubist PNG
DRY_RUN=true

# Art output (repo-local default; on Beelink use an absolute path)
ART_STORAGE_PATH=../art

# Required for real generations (DRY_RUN=false)
XAI_API_KEY=

# Models — adjust if your account catalog differs
XAI_CHAT_MODEL=grok-4-1-fast-reasoning
XAI_IMAGE_MODEL=grok-imagine-image

DEFAULT_STYLE=planet-core

# Events: rss (default, live headlines) | xai | hybrid
EVENTS_SOURCE=rss

# Edge text path: xai (default) or lemonade (Beelink local, text only)
EDGE_TEXT=xai
LEMONADE_URL=http://127.0.0.1:13305
LEMONADE_MODEL=Qwen3-4B-GGUF

# Scheduler off until you want hourly automation
SCHEDULE_ENABLED=false
# SCHEDULE_CRON=0 * * * *

# Optional later — v1 is download + post yourself
X_ACCOUNT_HANDLE=@tunastarlink
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
