# Copy to backend/.env.local for local dev.

DRY_RUN=true
ART_STORAGE_PATH=../art

XAI_API_KEY=
# Non-reasoning for brief+caption (cheap). Imagine is the real $ cost.
XAI_CHAT_MODEL=grok-4-1-fast-non-reasoning
XAI_IMAGE_MODEL=grok-imagine-image
XAI_IMAGE_SIZE=1792x1024
XAI_IMAGE_ASPECT_RATIO=16:9

DEFAULT_STYLE=data-tunnel
EVENTS_SOURCE=stream

# Lean RSS only — re-fetch at most every 45m. No X search by default.
RSS_INGEST_TTL_MINUTES=45
X_SEARCH_ENABLED=false
X_SEARCH_TTL_MINUTES=120
X_SEARCH_MAX_RESULTS=10

EDGE_TEXT=xai
LEMONADE_URL=http://127.0.0.1:13305
LEMONADE_MODEL=Qwen3-4B-GGUF

# OFF by default — no unattended fires. You click Generate when you want one.
SCHEDULE_ENABLED=false
SCHEDULE_INTERVAL_MINUTES=40
SCHEDULE_PEAK_START_HOUR=19
SCHEDULE_PEAK_END_HOUR=22
SCHEDULE_MAX_RUNS_PER_DAY=5
SCHEDULE_TIMEZONE=America/New_York
SCHEDULE_CRON=off (manual generate only)
# AUTO_PUBLISH=true  # post to X after a successful (manual) generate

# X OAuth 1.0a — @tunastarlink (post+media). Search is separate kill switch.
X_ACCOUNT_HANDLE=@tunastarlink
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
