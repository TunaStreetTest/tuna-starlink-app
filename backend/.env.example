# Copy to backend/.env.local for local dev.

# Free testing — no xAI spend, local placeholder PNG
DRY_RUN=true

# Art output (repo-local default; on Beelink use an absolute path)
ART_STORAGE_PATH=../art

# Required for real generations (DRY_RUN=false)
XAI_API_KEY=

# Models
XAI_CHAT_MODEL=grok-4-1-fast-reasoning
XAI_IMAGE_MODEL=grok-imagine-image
# Landscape series posts (avoid portrait "middle bar")
XAI_IMAGE_SIZE=1792x1024
XAI_IMAGE_ASPECT_RATIO=16:9

# Manual UI default; hourly schedule picks a style at random
DEFAULT_STYLE=data-tunnel

# stream = RSS injects into local stream; each run taps unused headlines
# also: rss | xai | hybrid
EVENTS_SOURCE=stream

# Edge text path: xai (default) or lemonade (Beelink local, text only)
EDGE_TEXT=xai
LEMONADE_URL=http://127.0.0.1:13305
LEMONADE_MODEL=Qwen3-4B-GGUF

# Peak US evenings Eastern (6pm–10pm inclusive): 18,19,20,21,22
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 18-22 * * *
SCHEDULE_TIMEZONE=America/New_York
# AUTO_PUBLISH=true

# X — @tunastarlink OAuth 1.0a (access tokens must be that account)
X_ACCOUNT_HANDLE=@tunastarlink
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
